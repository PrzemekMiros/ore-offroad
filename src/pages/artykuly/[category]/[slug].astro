---
import { Image } from "astro:assets";
import { existsSync, readFileSync } from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArticlesHero from "../../../layouts/heroes/ArticlesHero.astro";
import settings from "../../../content/ustawienia.json";
import { slugifyTitle } from "../../../lib/slugifyTitle";
import adVerticalJusn from "../../../assets/images/advertise/ad-vertical-jusn.png";
import adToughVertical from "../../../assets/images/advertise/ad-tough-vertical.png";

export const prerender = true;

const projectRoot = fileURLToPath(new URL("../../../..", import.meta.url));
const getArticleFsPath = (slugPath) => path.join(projectRoot, "src", "content", "artykuly", `${slugPath}.md`);
const toFsPath = (file) => {
  if (path.isAbsolute(file)) return file;
  if (file.startsWith("/src/")) return path.join(projectRoot, file.slice(1));
  if (file.startsWith("src/")) return path.join(projectRoot, file);
  return path.resolve(path.dirname(fileURLToPath(import.meta.url)), file);
};

const stripFrontmatter = (content) => content.replace(/^---[\s\S]*?---\s*/u, "");
const stripCodeBlocks = (content) => content.replace(/```[\s\S]*?```/g, " ");
const stripInlineCode = (content) => content.replace(/`[^`]*`/g, " ");
const stripHtml = (content) => content.replace(/<[^>]+>/g, " ");
const stripLinks = (content) => content.replace(/!?\[[^\]]*]\([^)]+\)/g, " ");
const stripRefLinks = (content) => content.replace(/!?\[[^\]]*]\[[^\]]*]/g, " ");

const countWords = (content) => {
  const cleaned = stripRefLinks(
    stripLinks(stripHtml(stripInlineCode(stripCodeBlocks(stripFrontmatter(content)))))
  )
    .replace(/[^\p{L}\p{N}]+/gu, " ")
    .trim();
  if (!cleaned) return 0;
  return cleaned.split(/\s+/).filter(Boolean).length;
};

const formatReadingTime = (words, wpm = 200) => {
  const minutes = Math.max(1, Math.ceil(words / wpm));
  const label = minutes === 1 ? "minuta" : minutes >= 2 && minutes <= 4 ? "minuty" : "minut";
  return `${minutes} ${label} czytania`;
};

const imageEntries = import.meta.glob("/src/content/artykuly/img/**/*", { eager: true });
const resolveArticleImage = (path) => {
  if (!path) return null;
  let normalized = path;
  if (normalized.startsWith("/content/posts/img/")) {
    const relativePath = normalized.slice("/content/posts/img/".length);
    normalized = `/src/content/artykuly/img/${relativePath}`;
  } else if (normalized.startsWith("/content/")) {
    normalized = `/src${normalized}`;
  }
  const entry = imageEntries[normalized];
  return entry?.default ?? null;
};

function getSlugPathFromFile(file) {
  return file.replace(/^.*content\/artykuly\//, "").replace(/\.md$/, "");
}
function getCategorySlug(frontmatter, slugPath) {
  const parts = slugPath.split("/");
  if (parts.length > 1) return parts[0];
  const categoryValue = Array.isArray(frontmatter?.category)
    ? frontmatter.category[0]
    : frontmatter?.category;
  return categoryValue ? slugifyTitle(categoryValue) : "artykuly";
}
function getArticleSlug(slugPath) {
  const parts = slugPath.split("/");
  return parts.length > 1 ? parts.slice(1).join("/") : slugPath;
}

export async function getStaticPaths() {
  const stripFrontmatterLocal = (content) => content.replace(/^---[\s\S]*?---\s*/u, "");
  const stripCodeBlocksLocal = (content) => content.replace(/```[\s\S]*?```/g, " ");
  const stripInlineCodeLocal = (content) => content.replace(/`[^`]*`/g, " ");
  const stripHtmlLocal = (content) => content.replace(/<[^>]+>/g, " ");
  const stripLinksLocal = (content) => content.replace(/!?\[[^\]]*]\([^)]+\)/g, " ");
  const stripRefLinksLocal = (content) => content.replace(/!?\[[^\]]*]\[[^\]]*]/g, " ");
  const countWordsLocal = (content) => {
    const cleaned = stripRefLinksLocal(
      stripLinksLocal(stripHtmlLocal(stripInlineCodeLocal(stripCodeBlocksLocal(stripFrontmatterLocal(content)))))
    )
      .replace(/[^\p{L}\p{N}]+/gu, " ")
      .trim();
    if (!cleaned) return 0;
    return cleaned.split(/\s+/).filter(Boolean).length;
  };
  const formatReadingTimeLocal = (words, wpm = 200) => {
    const minutes = Math.max(1, Math.ceil(words / wpm));
    const label = minutes === 1 ? "minuta" : minutes >= 2 && minutes <= 4 ? "minuty" : "minut";
    return `${minutes} ${label} czytania`;
  };
  const getSlugPathFromFileLocal = (file) =>
    file.replace(/^.*content\/artykuly\//, "").replace(/\.md$/, "");
  const getCategorySlugLocal = (frontmatter, slugPath) => {
    const parts = slugPath.split("/");
    if (parts.length > 1) return parts[0];
    const categoryValue = Array.isArray(frontmatter?.category)
      ? frontmatter.category[0]
      : frontmatter?.category;
    return categoryValue ? slugifyTitle(categoryValue) : "artykuly";
  };
  const getArticleSlugLocal = (slugPath) => {
    const parts = slugPath.split("/");
    return parts.length > 1 ? parts.slice(1).join("/") : slugPath;
  };
  const entries = import.meta.glob("../../../content/artykuly/**/*.md", { eager: true });
  const paths = await Promise.all(
    Object.entries(entries).map(async ([file, entry]) => {
      const slugPath = getSlugPathFromFileLocal(file);
      const categorySlug = getCategorySlugLocal(entry.frontmatter ?? {}, slugPath);
      const slug = getArticleSlugLocal(slugPath);
      const entryHeadings = typeof entry.getHeadings === "function"
        ? await entry.getHeadings()
        : entry.headings ?? [];
      let readingTime = null;
      let raw = null;
      if (typeof entry.rawContent === "function") {
        try {
          raw = entry.rawContent();
        } catch {
          raw = null;
        }
      }
      if (!raw) {
        const candidates = [toFsPath(file), getArticleFsPath(slugPath), file];
        for (const candidate of candidates) {
          try {
            if (existsSync(candidate)) {
              raw = readFileSync(candidate, "utf-8");
              break;
            }
          } catch {
            // continue
          }
        }
      }
      readingTime = raw ? formatReadingTimeLocal(countWordsLocal(raw)) : null;
      return {
        params: { category: categorySlug, slug },
        props: {
          artykul: { slug, categorySlug, readingTime, ...entry.frontmatter },
          Content: entry.Content,
          headings: entryHeadings,
        },
      };
    })
  );
  return paths;
}

const { artykul, Content, headings } = Astro.props;
const readingTime = artykul?.readingTime ?? null;
const allArticleEntries = import.meta.glob("../../../content/artykuly/**/*.md", { eager: true });
const allArticles = Object.entries(allArticleEntries).map(([file, entry]) => {
  const slugPath = getSlugPathFromFile(file);
  const categorySlug = getCategorySlug(entry.frontmatter ?? {}, slugPath);
  const slug = getArticleSlug(slugPath);
  return {
    slug,
    categorySlug,
    ...entry.frontmatter,
  };
});
const categories = Array.from(
  allArticles.reduce((set, article) => {
    const categoryValues = Array.isArray(article?.category)
      ? article.category
      : article?.category
      ? [article.category]
      : [];
    categoryValues.forEach((category) => {
      if (!category?.trim()) return;
      set.add(category.trim());
    });
    return set;
  }, new Set())
)
  .map((label) => ({ label, slug: slugifyTitle(label) }))
  .sort((a, b) => a.label.localeCompare(b.label, "pl-PL"));
const getTag = (article) => {
  const tag = Array.isArray(article?.tags) ? article.tags[0] : article?.tags;
  return tag ?? "Artykul";
};
const getCategoryLabel = (article) => {
  const category = Array.isArray(article?.category) ? article.category[0] : article?.category;
  return category ?? "Artykul";
};
allArticles.sort((a, b) => {
  const aDate = a?.date ? new Date(a.date).getTime() : 0;
  const bDate = b?.date ? new Date(b.date).getTime() : 0;
  return bDate - aDate;
});
const currentCategorySlug = artykul?.categorySlug ?? null;
const relatedArticles = currentCategorySlug
  ? allArticles
      .filter((item) => item?.categorySlug === currentCategorySlug && item?.slug !== artykul?.slug)
      .slice(0, 6)
  : [];
const inlineLinkArticle = relatedArticles[0] ?? null;
const shuffle = (items) => {
  const array = [...items];
  for (let i = array.length - 1; i > 0; i -= 1) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
  return array;
};
const crossCategoryArticles = shuffle(
  allArticles.filter(
    (item) =>
      item?.slug !== artykul?.slug &&
      item?.categorySlug &&
      item?.categorySlug !== currentCategorySlug
  )
).slice(0, 6);
const headerImage = resolveArticleImage(artykul?.tileImage ?? artykul?.thumbnail);
const headerImageUrl = headerImage?.src ?? headerImage;
const { site } = Astro;
const baseUrl = site ? site.toString().replace(/\/$/, "") : "";
const articleUrl = baseUrl
  ? `${baseUrl}/artykuly/${artykul?.categorySlug ?? ""}/${artykul?.slug ?? ""}/`
  : `/artykuly/${artykul?.categorySlug ?? ""}/${artykul?.slug ?? ""}/`;
const siteName = settings.siteTitle ?? "Strona";
const siteLogo = settings.logo ? (baseUrl ? `${baseUrl}${settings.logo}` : settings.logo) : "";
const authorName = artykul?.author ?? "Redakcja";
const datePublished = artykul?.date ? new Date(artykul.date) : null;
const dateModified = artykul?.updated ? new Date(artykul.updated) : datePublished;

if (!artykul) {
  return Astro.redirect('/artykuly');
}
---

<BaseLayout
  title={artykul.title ?? artykul.slug} 
  description={artykul.description}
  showHero={false}
  robots={artykul.robots}
>
  <ArticlesHero 
    title={artykul.title ?? artykul.slug} 
    lead={artykul.description}
    tags={artykul.tags}
    date={artykul.date}
    headerImage={headerImage}
    readingTime={readingTime}
  />
  <article
    class="pt-8 pb-20 z-50"
    itemscope
    itemtype="https://schema.org/BlogPosting"
  >
    <meta itemprop="mainEntityOfPage" content={articleUrl} />
    <meta itemprop="url" content={articleUrl} />
    <meta itemprop="headline" content={artykul.title ?? artykul.slug} />
    {artykul.description ? <meta itemprop="description" content={artykul.description} /> : null}
    {datePublished ? <meta itemprop="datePublished" content={datePublished.toISOString()} /> : null}
    {dateModified ? <meta itemprop="dateModified" content={dateModified.toISOString()} /> : null}
    {headerImageUrl ? <meta itemprop="image" content={headerImageUrl} /> : null}
    <div itemprop="author" itemscope itemtype="https://schema.org/Person">
      <meta itemprop="name" content={authorName} />
    </div>
    <div itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
      <meta itemprop="name" content={siteName} />
      {siteLogo ? <meta itemprop="logo" content={siteLogo} /> : null}
    </div>
    <div class="grid gap-12 grid-cols-1 lg:grid-cols-[260px_minmax(0,1fr)_260px]">
      <aside class="hidden lg:block mt-2">
        <div class="sticky top-38 space-y-4">
          <h3 class="text-xs font-semibold uppercase tracking-[0.2em] mb-6 border-l-2 border-[var(--accent)] pl-4">Spis treści</h3>
          {headings?.length ? (
            <ol class="space-y-2 text-sm text-[var(--muted)]" data-toc>
              {headings
                .filter((h) => h.depth === 2)
                .map((heading) => (
                  <li>
                    <a
                      class="transition-colors"
                      href={`#${heading.slug}`}
                      data-toc-link
                      data-toc-target={heading.slug}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
            </ol>
          ) : (
            <p class="text-xs text-[var(--muted)]">Brak spisu treści</p>
          )}
          <div class="advise-wrap mt-8">
            <a href="https://jusndesigneurope.com/" target="_blank">
              <Image
                src={adVerticalJusn}
                alt="Reklama"
                class="w-full h-auto transition-[filter] duration-500"
                widths={[300, 600]}
                sizes="(max-width: 1024px) 100vw, 300px"
                loading="lazy"
                decoding="async"
              />
            </a>
          </div>
        </div>
      </aside>

      <div class="space-y-12">
        {Content ? (
  <section
    id="article-content"
    class="space-y-6 text-[16px] leading-relaxed text-[var(--text)] sm:text-[17px] sm:leading-relaxed 
    [&>a]:underline [&>a]:decoration-[var(--accent)] [&>a]:underline-offset-4 [&>a]:font-medium hover:[&>a]:text-[var(--accent)]
    [&>blockquote]:border-l-4 [&>blockquote]:border-[var(--accent)] [&>blockquote]:pl-6 [&>blockquote]:italic [&>blockquote]:text-[var(--muted)] 
    [&>h2]:mt-10 [&>h2]:mb-4 [&>h2]:text-2xl [&>h2]:font-semibold [&>h2]:tracking-tight [&>h2]:text-[var(--text)] [&>h2]:scroll-mt-[144px]
    [&>h3]:mt-7 [&>h3]:mb-3 [&>h3]:text-xl [&>h3]:font-semibold [&>h3]:text-[var(--text)] 
    [&>hr]:my-8 [&>hr]:border-[var(--border)] 
    [&>p]:mb-5 [&>p]:last:mb-0"
  >
    <Content />
  </section>
        ) : null}

        {inlineLinkArticle ? (
          <p class="text-[15px] leading-relaxed text-[var(--text)]">
            Jeśli chcesz pogłębić wątek, zobacz także{" "}
            <a
              class="underline decoration-[var(--accent)] underline-offset-4 font-medium hover:text-[var(--accent)]"
              href={`/artykuly/${inlineLinkArticle?.categorySlug ?? ""}/${inlineLinkArticle?.slug ?? ""}/`}
            >
              {inlineLinkArticle?.title ?? inlineLinkArticle?.slug}
            </a>
            .
          </p>
        ) : null}

        {relatedArticles.length ? (
          <section class="pt-6">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold text-[var(--text)]">Może Cię zainteresować</h2>
              <a href="/artykuly/" class="text-[11px] uppercase tracking-widest text-[var(--accent)] hover:text-[var(--accent)]">Wszystkie</a>
            </div>
            <div class="mt-5 grid gap-6">
              {relatedArticles.map((item) => {
                const itemImage = resolveArticleImage(item?.tileImage ?? item?.thumbnail);
                const itemUrl = baseUrl
                  ? `${baseUrl}/artykuly/${item?.categorySlug ?? ""}/${item?.slug ?? ""}/`
                  : `/artykuly/${item?.categorySlug ?? ""}/${item?.slug ?? ""}/`;
                const categoryLabel = getCategoryLabel(item);
                return (
                  <a class="group grid grid-cols-1 md:grid-cols-2 gap-3 rounded-xl border border-[var(--border)] bg-white/80 p-3 hover:shadow-sm" href={itemUrl}>
                    <div class="shrink-0 overflow-hidden rounded-lg border border-black/10">
                      {itemImage ? (
                        <Image
                          class="h-40 w-full object-cover"
                          src={itemImage}
                          alt={item?.title ?? item?.slug}
                          widths={[560, 340]}
                          sizes="80px"
                          loading="lazy"
                          placeholder="blur"
                        />
                      ) : (
                        <div class="h-full w-full bg-black/5"></div>
                      )}
                    </div>
                    <div class="flex flex-col gap-1">
                      {categoryLabel ? (
                        <span class="text-[11px] font-semibold uppercase tracking-[0.05em] text-[var(--accent)]">
                          {categoryLabel}
                        </span>
                      ) : null}
                      <span class="text-lg font-semibold leading-snug text-black line-clamp-2">
                        {item?.title ?? item?.slug}
                      </span>
                      {item?.description ? (
                        <p class="text-sm leading-relaxed text-black/70 line-clamp-2">{item.description}</p>
                      ) : null}
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        ) : null}
      </div>

      <aside class="space-y-6 mt-2">
        <div class="sticky top-38">
        <div class="space-y-5">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-xs font-semibold uppercase tracking-[0.2em] border-l-2 border-[var(--accent)] pl-4">Kategorie</h3>
            <a href="/artykuly/" class="text-[11px] uppercase tracking-widest text-[var(--accent)] hover:text-[var(--accent)]">Wszystkie</a>
          </div>
          {categories.length ? (
            <ul class="space-y-2">
              {categories.map((category) => (
                <li>
                  <a
                    class="block rounded-xl border border-[var(--border)] bg-white/80 px-4 py-3 text-sm text-[var(--muted)] transition-all hover:border-[var(--accent)] hover:text-[var(--accent)]"
                    href={`/${category.slug}/`}
                  >
                    {category.label}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-[var(--muted)]">Brak kategorii</p>
          )}
        </div>
          <div class="advise-wrap mt-8">
            <a href="https://toughdog-poland.com/" target="_blank">
              <Image
                src={adToughVertical}
                alt="Reklama"
                class="w-full h-auto transition-[filter] duration-500"
                widths={[300, 600]}
                sizes="(max-width: 1024px) 100vw, 300px"
                loading="lazy"
                decoding="async"
              />
            </a>
          </div>
        </div>
      </aside>
    </div>
      {crossCategoryArticles.length ? (
      <section class="mx-auto max-w-7xl space-y-6 pt-6 mt-16 border-t border-black/10">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-[var(--text)]">Przeczytaj też</h2>
          <a href="/artykuly/" class="flex items-center gap-3 group text-black/90 font-bold text-[11px] uppercase tracking-widest hover:text-orange-600 transition-colors hidden md:block">
            Wszystkie wpisy
            <span class="text-orange-600 text-lg -translate-y-0.5 group-hover:translate-x-1 transition-transform">&gt;&gt;&gt;</span>
          </a>
        </div>
        <div class="grid gap-5 md:grid-cols-3">
          {crossCategoryArticles.map((item) => {
            const itemImage = resolveArticleImage(item?.tileImage ?? item?.thumbnail);
            const itemUrl = baseUrl
              ? `${baseUrl}/artykuly/${item?.categorySlug ?? ""}/${item?.slug ?? ""}/`
              : `/artykuly/${item?.categorySlug ?? ""}/${item?.slug ?? ""}/`;
            return (
              <a
                class="group flex h-full w-full flex-col rounded-2xl border border-[var(--border)] bg-white px-5 pb-8 pt-6 md:px-6 transition-transform hover:scale-[1.02]"
                href={itemUrl}
              >
                <div class="mb-4 flex items-start justify-between">
                  <span class="flex items-center gap-2 rounded-full border border-black/20 px-3 py-1.5 text-[10px] font-bold uppercase text-black">
                    <span class="flex h-3 w-3 items-center justify-center rounded-sm bg-[var(--accent)] text-[8px] text-white">II</span>
                    {getCategoryLabel(item)}
                  </span>
                  <div class="rounded-full border border-black/20 p-2">
                    <svg class="h-3 w-3 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                  </div>
                </div>

                <div class="mb-6">
                  {itemImage ? (
                    <Image
                      class="h-[185px] w-full rounded-xl border border-black/10 object-cover"
                      src={itemImage}
                      alt={item?.title ?? item?.slug}
                      widths={[360, 520, 720]}
                      sizes="(max-width: 900px) 100vw, 320px"
                      loading="lazy"
                      placeholder="blur"
                    />
                  ) : (
                    <div class="grid h-[185px] w-full place-items-center rounded-xl border border-black/10 bg-black/5 text-[11px] uppercase tracking-widest text-black/60">
                      Brak zdjecia
                    </div>
                  )}
                </div>

                <div>
                  <h3 class="mb-3 text-xl font-semibold leading-snug text-black line-clamp-2">
                    {item?.title ?? item?.slug}
                  </h3>
                  {item?.description ? (
                    <p class="text-sm leading-relaxed text-black/70 line-clamp-2">{item.description}</p>
                  ) : null}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ) : null}
  </article>
  <script>
    const initToc = () => {
      const tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));
      const headings = tocLinks
        .map((link) => document.getElementById(link.dataset.tocTarget))
        .filter(Boolean);

      if (!tocLinks.length || !headings.length) return () => {};

      const offset = 144;
      const setActive = (id) => {
        tocLinks.forEach((link) => {
          const isActive = link.dataset.tocTarget === id;
          link.classList.toggle("text-[var(--accent)]", isActive);
        });
      };

      const updateActive = () => {
        const scrollPos = window.scrollY + offset + 1;
        let current = headings[0];
        for (const heading of headings) {
          const top = heading.offsetTop;
          if (top <= scrollPos) {
            current = heading;
          } else {
            break;
          }
        }
        if (current) setActive(current.id);
      };

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          updateActive();
          ticking = false;
        });
      };

      const clickHandlers = new Map();
      tocLinks.forEach((link) => {
        const handler = (event) => {
          event.preventDefault();
          const target = document.getElementById(link.dataset.tocTarget);
          if (target) {
            const top = target.getBoundingClientRect().top + window.scrollY - offset;
            window.scrollTo({ top, behavior: "smooth" });
            setActive(target.id);
            history.replaceState(null, "", `#${target.id}`);
            setTimeout(updateActive, 0);
          }
        };
        clickHandlers.set(link, handler);
        link.addEventListener("click", handler);
      });

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll);

      updateActive();

      return () => {
        window.removeEventListener("scroll", onScroll);
        window.removeEventListener("resize", onScroll);
        clickHandlers.forEach((handler, link) => {
          link.removeEventListener("click", handler);
        });
      };
    };

    const runTocInit = () => {
      if (window.__tocCleanup) {
        window.__tocCleanup();
        window.__tocCleanup = null;
      }
      window.__tocCleanup = initToc();
    };

    const initRadGalleryLightbox = () => {
      const articleContent = document.querySelector("#article-content");
      if (!articleContent) return () => {};
      let grid = articleContent.querySelector(".rad-gallery-grid");
      let items = [];

      if (grid) {
        items = Array.from(grid.querySelectorAll(".rad-gallery-thumb img"))
          .map((img, index) => ({
            src: img.currentSrc || img.src,
            alt: img.alt || `Raduszczanka ${index + 1}`,
          }))
          .filter((item) => item.src);
      } else {
        const galleryImages = Array.from(articleContent.querySelectorAll("img")).filter((img) =>
          (img.currentSrc || img.src || "").toLowerCase().includes("raduszczanka")
        );
        if (!galleryImages.length) return () => {};

        const galleryNodes = Array.from(
          new Set(
            galleryImages.map((img) => img.closest("p, figure") ?? img.parentElement).filter(Boolean)
          )
        );
        if (!galleryNodes.length) return () => {};

        items = galleryImages
          .map((img, index) => ({
            src: img.currentSrc || img.src,
            alt: img.alt || `Raduszczanka ${index + 1}`,
          }))
          .filter((item) => item.src);
        if (!items.length) return () => {};

        grid = document.createElement("div");
        grid.className = "rad-gallery-grid";

        items.forEach((item, index) => {
          const button = document.createElement("button");
          button.type = "button";
          button.className = "rad-gallery-thumb";
          button.dataset.index = String(index);
          button.setAttribute("aria-label", `Otworz zdjecie ${index + 1}`);

          const thumb = document.createElement("img");
          thumb.src = item.src;
          thumb.alt = item.alt;
          thumb.loading = "lazy";
          thumb.decoding = "async";

          button.appendChild(thumb);
          grid.appendChild(button);
        });

        const firstNode = galleryNodes[0];
        const previous = firstNode.previousElementSibling;
        const headingBeforeGallery =
          previous && /^H[2-4]$/i.test(previous.tagName) ? previous : null;

        if (headingBeforeGallery) {
          headingBeforeGallery.insertAdjacentElement("afterend", grid);
        } else {
          firstNode.insertAdjacentElement("beforebegin", grid);
        }
        galleryNodes.forEach((node) => node.remove());
      }
      if (!items.length || !grid) return () => {};

      const overlay = document.createElement("div");
      overlay.className = "rad-lightbox";
      overlay.hidden = true;
      overlay.innerHTML = `
        <button class="rad-lightbox-close" type="button" aria-label="Zamknij">&times;</button>
        <button class="rad-lightbox-prev" type="button" aria-label="Poprzednie">&#10094;</button>
        <figure class="rad-lightbox-figure">
          <img class="rad-lightbox-image" alt="" />
          <figcaption class="rad-lightbox-caption"></figcaption>
        </figure>
        <button class="rad-lightbox-next" type="button" aria-label="Nastepne">&#10095;</button>
      `;
      document.body.appendChild(overlay);

      const imageEl = overlay.querySelector(".rad-lightbox-image");
      const captionEl = overlay.querySelector(".rad-lightbox-caption");
      const closeButton = overlay.querySelector(".rad-lightbox-close");
      const prevButton = overlay.querySelector(".rad-lightbox-prev");
      const nextButton = overlay.querySelector(".rad-lightbox-next");
      let activeIndex = 0;

      const render = () => {
        const item = items[activeIndex];
        imageEl.src = item.src;
        imageEl.alt = item.alt;
        captionEl.textContent = `${activeIndex + 1} / ${items.length}`;
      };

      const open = (index) => {
        activeIndex = index;
        render();
        overlay.hidden = false;
        document.body.classList.add("rad-lightbox-open");
      };

      const close = () => {
        overlay.hidden = true;
        document.body.classList.remove("rad-lightbox-open");
      };

      const move = (step) => {
        activeIndex = (activeIndex + step + items.length) % items.length;
        render();
      };

      const onThumbClick = (event) => {
        const thumb = event.target.closest(".rad-gallery-thumb");
        if (!thumb) return;
        open(Number(thumb.dataset.index ?? 0));
      };
      const onOverlayClick = (event) => {
        if (event.target === overlay) close();
      };
      const onKeyDown = (event) => {
        if (overlay.hidden) return;
        if (event.key === "Escape") close();
        if (event.key === "ArrowLeft") move(-1);
        if (event.key === "ArrowRight") move(1);
      };

      grid.addEventListener("click", onThumbClick);
      closeButton.addEventListener("click", close);
      prevButton.addEventListener("click", () => move(-1));
      nextButton.addEventListener("click", () => move(1));
      overlay.addEventListener("click", onOverlayClick);
      window.addEventListener("keydown", onKeyDown);

      return () => {
        grid.removeEventListener("click", onThumbClick);
        closeButton.removeEventListener("click", close);
        overlay.removeEventListener("click", onOverlayClick);
        window.removeEventListener("keydown", onKeyDown);
        overlay.remove();
      };
    };

    const runRadGalleryLightboxInit = () => {
      if (window.__radGalleryLightboxCleanup) {
        window.__radGalleryLightboxCleanup();
        window.__radGalleryLightboxCleanup = null;
      }
      window.__radGalleryLightboxCleanup = initRadGalleryLightbox();
    };

    runTocInit();
    runRadGalleryLightboxInit();
    document.addEventListener("astro:page-load", runTocInit);
    document.addEventListener("astro:page-load", runRadGalleryLightboxInit);
    document.addEventListener("astro:after-swap", runTocInit);
    document.addEventListener("astro:after-swap", runRadGalleryLightboxInit);
  </script>
  <style is:global>
    .rad-gallery-grid {
      margin-top: 1.25rem;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
    }
    .rad-gallery-thumb {
      display: block;
      border: 0;
      padding: 0;
      background: transparent;
      cursor: zoom-in;
      border-radius: 0.75rem;
      overflow: hidden;
    }
    .rad-gallery-thumb img {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      transition: transform 180ms ease;
    }
    .rad-gallery-thumb:hover img {
      transform: scale(1.03);
    }
    .rad-lightbox-open {
      overflow: hidden;
    }
    .rad-lightbox {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 1rem;
      padding: 1.25rem;
      background: rgba(0, 0, 0, 0.92);
    }
    .rad-lightbox[hidden] {
      display: none;
    }
    .rad-lightbox-figure {
      margin: 0;
      display: grid;
      gap: 0.75rem;
      justify-items: center;
    }
    .rad-lightbox-image {
      max-width: min(92vw, 1200px);
      max-height: 82vh;
      border-radius: 0.5rem;
      object-fit: contain;
    }
    .rad-lightbox-caption {
      color: #f1f5f9;
      font-size: 0.875rem;
      letter-spacing: 0.02em;
    }
    .rad-lightbox-close,
    .rad-lightbox-prev,
    .rad-lightbox-next {
      border: 0;
      background: rgba(255, 255, 255, 0.14);
      color: #fff;
      width: 44px;
      height: 44px;
      border-radius: 9999px;
      cursor: pointer;
      line-height: 1;
      display: grid;
      place-items: center;
      font-size: 1.2rem;
    }
    .rad-lightbox-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      font-size: 1.5rem;
    }
    @media (max-width: 640px) {
      .rad-gallery-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
      .rad-lightbox {
        grid-template-columns: 1fr;
        justify-items: center;
        gap: 0.75rem;
      }
      .rad-lightbox-prev,
      .rad-lightbox-next {
        position: fixed;
        bottom: 1rem;
      }
      .rad-lightbox-prev {
        left: 1rem;
      }
      .rad-lightbox-next {
        right: 1rem;
      }
    }
  </style>
</BaseLayout>
