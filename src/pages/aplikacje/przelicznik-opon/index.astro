---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Kalkulator / przelicznik wymiarów opon – dobierz odpowiedni rozmiar i sprawdź zamienniki"
  description="Kalkulator wymiarów opon calowych i metrycznych."
  showHero={false}
>
  <section class="pt-16 mt-24 pb-20">
    <div class="">
      <div class="rounded-2xl border border-black/10 bg-gradient-to-br from-slate-50 via-white to-orange-50 p-5 md:p-8">
        <header class="mb-6 rounded-xl border border-black/10 bg-white/80 p-5 md:p-7">
          <h1 class="text-2xl font-semibold text-[var(--text)] md:text-3xl">Przelicznik wymiarów opon</h1>
          <p class="mt-3 text-md text-[var(--muted)]">
Kalkulator wymiarów opon to praktyczne narzędzie, które pozwala szybko przeliczyć parametry
    opon metrycznych oraz calowych. Dzięki niemu możesz sprawdzić szerokość, wysokość profilu,
    średnicę zewnętrzną oraz obwód opony, a także łatwo porównać różne rozmiary ogumienia.
          </p>
          <p class="mt-3 text-[var(--muted)]">
 Narzędzie automatycznie synchronizuje wartości pomiędzy oznaczeniami metrycznymi i calowymi,
    co znacznie ułatwia dobór odpowiedniego rozmiaru opony do samochodu terenowego, SUV-a,
    auta osobowego czy pojazdu użytkowego.
          </p>
        </header>

        <div class="grid gap-5 md:grid-cols-3">
          <fieldset class="rounded-xl border border-black/10 bg-white/80 p-4 md:p-6">
            <legend class="rounded-lg border border-black/10 bg-white px-3 py-1 font-semibold">Opona calowa</legend>

            <label class="mb-1 mt-4 block text-xs font-semibold uppercase tracking-[0.12em] text-black/70" for="height-in">Wysokość opony [cale]</label>
            <div class="number-input">
              <button type="button" data-step-target="height-in" data-step-value="-0.5">-</button>
              <input id="height-in" type="number" value="30" step="0.5" min="24" max="45" />
              <button type="button" data-step-target="height-in" data-step-value="0.5">+</button>
            </div>

            <label class="mb-1 mt-4 block text-xs font-semibold uppercase tracking-[0.12em] text-black/70" for="width-in">Szerokość opony [cale]</label>
            <div class="number-input">
              <button type="button" data-step-target="width-in" data-step-value="-0.5">-</button>
              <input id="width-in" type="number" value="12.5" step="0.5" min="5" max="16" />
              <button type="button" data-step-target="width-in" data-step-value="0.5">+</button>
            </div>

            <label class="mb-1 mt-4 block text-xs font-semibold uppercase tracking-[0.12em] text-black/70" for="rim-in">Średnica osadzenia [cale]</label>
            <div class="number-input">
              <button type="button" data-step-target="rim-in" data-step-value="-0.5">-</button>
              <input id="rim-in" type="number" value="15" step="0.5" min="12" max="45" />
              <button type="button" data-step-target="rim-in" data-step-value="0.5">+</button>
            </div>
          </fieldset>

          <fieldset class="rounded-xl border border-black/10 bg-white/80 p-4 md:p-6">
            <legend class="rounded-lg border border-black/10 bg-white px-3 py-1 font-semibold">Opona metryczna</legend>

            <label class="mb-1 mt-4 block text-xs font-semibold uppercase tracking-[0.12em] text-black/70" for="width-mm">Szerokość opony [mm]</label>
            <div class="number-input">
              <button type="button" data-step-target="width-mm" data-step-value="-5">-</button>
              <input id="width-mm" type="number" value="315" step="5" min="150" max="365" />
              <button type="button" data-step-target="width-mm" data-step-value="5">+</button>
            </div>

            <label class="mb-1 mt-4 block text-xs font-semibold uppercase tracking-[0.12em] text-black/70" for="aspect-mm">Profil opony [%]</label>
            <div class="number-input">
              <button type="button" data-step-target="aspect-mm" data-step-value="-1">-</button>
              <input id="aspect-mm" type="number" value="75" step="1" min="30" max="100" />
              <button type="button" data-step-target="aspect-mm" data-step-value="1">+</button>
            </div>

            <label class="mb-1 mt-4 block text-xs font-semibold uppercase tracking-[0.12em] text-black/70" for="rim-mm">Średnica osadzenia [cale]</label>
            <div class="number-input">
              <button type="button" data-step-target="rim-mm" data-step-value="-0.5">-</button>
              <input id="rim-mm" type="number" value="15" step="0.5" min="12" max="44" />
              <button type="button" data-step-target="rim-mm" data-step-value="0.5">+</button>
            </div>
          </fieldset>
        </div>

        <div class="grid gap-5 md:grid-cols-3 mb-12">
          <div class="mt-6 rounded-xl border border-black/10 bg-white/80 p-4 md:p-6">
            <table class="w-full border-collapse">
              <tbody>
                <tr class="border-b border-black/10">
                  <td class="py-2 font-semibold text-[var(--text)]">Szerokość opony [mm]</td>
                  <td class="py-2 text-right"><input type="text" id="out-width" readonly class="result-input" /></td>
                </tr>
                <tr class="border-b border-black/10">
                  <td class="py-2 font-semibold text-[var(--text)]">Wysokość profilu [mm]</td>
                  <td class="py-2 text-right"><input type="text" id="out-profile" readonly class="result-input" /></td>
                </tr>
                <tr class="border-b border-black/10">
                  <td class="py-2 font-semibold text-[var(--text)]">Średnica zewnętrzna [mm]</td>
                  <td class="py-2 text-right"><input type="text" id="out-diameter" readonly class="result-input" /></td>
                </tr>
                <tr>
                  <td class="py-2 font-semibold text-[var(--text)]">Obwód opony [mm]</td>
                  <td class="py-2 text-right"><input type="text" id="out-circumference" readonly class="result-input" /></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

          <div id="article-content">
          <h2 class="text-xl font-semibold text-[var(--text)] md:text-3xl">Jak działa kalkulator opon?</h2>
          <p class="mt-3 text-[var(--muted)]">
Wystarczy uzupełnić dowolne pola dotyczące szerokości, profilu, średnicy lub obwodu opony.
    Kalkulator automatycznie przeliczy pozostałe parametry i zsynchronizuje oba formaty oznaczeń.
          </p>
          <p class="mt-3 text-[var(--muted)]">
  Możesz korzystać zarówno z:
          </p>
          <ul class="text-[var(--muted)]">
    <li>oznaczeń metrycznych,</li>
    <li>oznaczeń calowych,</li>
    <li>średnicy zewnętrznej opony,</li>
    <li>obwodu opony.</li>
  </ul>
            <h2 class="text-xl font-semibold text-[var(--text)] md:text-3xl">Opona metryczna – co oznaczają parametry?</h2>
          <p class="mt-3 text-[var(--muted)]">
    Oznaczenia metryczne są najczęściej stosowane w samochodach osobowych i SUV-ach.
    Przykładowy rozmiar opony:
          </p>
          <p class="mt-3 font-semibold text-[var(--text)]">
    <strong>205/55 R16</strong>
  </p>

  <ul class="text-[var(--muted)]">
    <li><strong>205</strong> – szerokość opony w milimetrach,</li>
    <li><strong>55</strong> – profil opony wyrażony w procentach,</li>
    <li><strong>R16</strong> – średnica felgi podana w calach.</li>
  </ul>

  <h2 class="mt-8 text-xl font-semibold text-[var(--text)] md:text-3xl">Opona calowa – jak odczytywać rozmiar?</h2>

  <p class="mt-3 leading-relaxed text-[var(--muted)]">
    Oznaczenia calowe są popularne przede wszystkim w samochodach terenowych, pick-upach,
    klasycznych autach 4x4 oraz pojazdach off-roadowych.
  </p>

  <p class="mt-3 leading-relaxed text-[var(--muted)]">
    Kalkulator umożliwia szybkie przeliczenie:
  </p>

  <ul class="text-[var(--muted)]">
    <li>wysokości opony w calach,</li>
    <li>szerokości opony w calach,</li>
    <li>średnicy osadzenia.</li>
  </ul>

  <p class="mt-3 leading-relaxed text-[var(--muted)]">
    Dzięki temu łatwo porównasz rozmiary terenowe z klasycznymi oznaczeniami metrycznymi.
  </p>

  <h2 class="mt-8 text-xl font-semibold text-[var(--text)] md:text-3xl">Jakie parametry oblicza kalkulator?</h2>

  <p class="mt-3 leading-relaxed text-[var(--muted)]">
    Po wpisaniu danych kalkulator automatycznie wylicza:
  </p>

  <ul class="text-[var(--muted)]">
    <li><strong>Szerokość opony [mm]</strong> – rzeczywistą szerokość ogumienia,</li>
    <li><strong>Wysokość profilu [mm]</strong> – wysokość boku opony,</li>
    <li><strong>Średnicę zewnętrzną [mm]</strong> – całkowitą średnicę koła,</li>
    <li><strong>Obwód opony [mm]</strong> – długość pełnego obrotu koła.</li>
  </ul>

  <h2 class="mt-8 text-xl font-semibold text-[var(--text)] md:text-3xl">Dlaczego średnica i obwód opony są tak ważne?</h2>

  <p class="mt-3 leading-relaxed text-[var(--muted)]">
    Nawet niewielka zmiana średnicy lub obwodu opony może wpływać na:
  </p>

  <ul class="text-[var(--muted)]">
    <li>wskazania prędkościomierza,</li>
    <li>działanie systemów ABS i ESP,</li>
    <li>komfort jazdy,</li>
    <li>zużycie paliwa,</li>
    <li>pracę skrzyni biegów i napędu 4x4,</li>
    <li>prześwit pojazdu.</li>
  </ul>

  <p class="mt-3 leading-relaxed text-[var(--muted)]">
    Dlatego przed zmianą rozmiaru opon warto dokładnie sprawdzić wszystkie parametry
    przy pomocy kalkulatora.
  </p>

  <h2 class="mt-8 text-xl font-semibold text-[var(--text)] md:text-3xl">Kiedy warto korzystać z kalkulatora wymiarów opon?</h2>

  <p class="mt-3 leading-relaxed text-[var(--muted)]">
    Kalkulator przydaje się szczególnie podczas:
  </p>

  <ul class="text-[var(--muted)]">
    <li>zmiany rozmiaru felg,</li>
    <li>doboru zamienników opon,</li>
    <li>modyfikacji samochodu terenowego lub SUV-a,</li>
    <li>podnoszenia zawieszenia,</li>
    <li>porównywania opon calowych i metrycznych,</li>
    <li>doboru większych opon off-roadowych.</li>
  </ul>

  <h2 class="mt-8 text-xl font-semibold text-[var(--text)] md:text-3xl">Najczęstsze błędy przy doborze opon</h2>

  <ul class="text-[var(--muted)]">
    <li>wybór zbyt dużej średnicy opony,</li>
    <li>brak sprawdzenia obwodu koła,</li>
    <li>niedopasowanie szerokości opony do felgi,</li>
    <li>pomijanie wpływu zmiany rozmiaru na napęd i zawieszenie,</li>
    <li>kierowanie się wyłącznie wyglądem opony.</li>
  </ul>

  <p class="mt-3 leading-relaxed text-[var(--muted)]">
    Nieprawidłowo dobrane ogumienie może powodować ocieranie o nadkola,
    błędne wskazania licznika oraz szybsze zużycie podzespołów.
  </p>



  <p class="mt-3 leading-relaxed text-[var(--muted)]">
    Kalkulator wymiarów opon to wygodne narzędzie dla każdego kierowcy, który chce szybko
    sprawdzić parametry opon i porównać różne rozmiary ogumienia. Automatyczne przeliczanie
    wartości pomiędzy systemem metrycznym i calowym pozwala łatwo dobrać odpowiednie opony
    zarówno do samochodów osobowych, jak i terenowych.
  </p>

  <p class="mt-3 leading-relaxed text-[var(--muted)]">
    Skorzystaj z kalkulatora, aby bezpiecznie dobrać rozmiar opon, uniknąć problemów
    z montażem oraz sprawdzić wpływ zmian na parametry pojazdu.
  </p>

          </div>
      </div>
    </div>
  </section>

  <style>
    .number-input {
      display: inline-flex;
      align-items: center;
      overflow: hidden;
      border: 1px solid rgba(15, 23, 42, 0.2);
      border-radius: 8px;
      background: #fff;
    }
    .number-input input[type="number"] {
      width: 84px;
      border: 0;
      outline: none;
      text-align: center;
      padding: 8px 0;
      font-size: 14px;
      appearance: textfield;
      background: #fff;
    }
    .number-input input::-webkit-outer-spin-button,
    .number-input input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }
    .number-input button {
      width: 32px;
      height: 34px;
      border: 0;
      cursor: pointer;
      color: #fff;
      background: #0f172a;
      transition: background 0.2s;
    }
    .number-input button:hover {
      background: var(--accent);
    }
    .result-input {
      width: 108px;
      border: 1px solid rgba(15, 23, 42, 0.2);
      border-radius: 6px;
      background: #fff;
      padding: 7px 8px;
      text-align: center;
      font-weight: 600;
      color: #0f172a;
    }
  </style>

  <script>
    const initTireCalculator = () => {
      const heightInField = document.getElementById("height-in");
      const widthInField = document.getElementById("width-in");
      const rimInField = document.getElementById("rim-in");
      const widthMMField = document.getElementById("width-mm");
      const aspectField = document.getElementById("aspect-mm");
      const rimMMField = document.getElementById("rim-mm");

      if (
        !heightInField ||
        !widthInField ||
        !rimInField ||
        !widthMMField ||
        !aspectField ||
        !rimMMField
      ) {
        return;
      }

      if (heightInField.dataset.calculatorReady === "true") {
        return;
      }

      heightInField.dataset.calculatorReady = "true";

      let blockSync = false;

      const roundToStep = (value, step) => Math.round(value / step) * step;

      const updateResultsFromMM = (widthMM, aspect, rimIn) => {
        const sidewallMM = widthMM * (aspect / 100);
        const diameterMM = rimIn * 25.4 + 2 * sidewallMM;
        const circumferenceMM = diameterMM * Math.PI;

        document.getElementById("out-width").value = widthMM.toFixed(0);
        document.getElementById("out-profile").value = sidewallMM.toFixed(0);
        document.getElementById("out-diameter").value = diameterMM.toFixed(0);
        document.getElementById("out-circumference").value = circumferenceMM.toFixed(0);
      };

      const syncFromMetric = (widthMM, aspect, rimIn) => {
        const sidewallMM = widthMM * (aspect / 100);
        const heightMM = 2 * sidewallMM + rimIn * 25.4;
        let heightIn = heightMM / 25.4;
        let widthIn = widthMM / 25.4;

        heightIn = roundToStep(heightIn, parseFloat(heightInField.step));
        widthIn = roundToStep(widthIn, parseFloat(widthInField.step));
        rimIn = roundToStep(rimIn, parseFloat(rimInField.step));

        heightInField.value = heightIn.toFixed(2);
        widthInField.value = widthIn.toFixed(2);
        rimInField.value = rimIn.toFixed(2);

        updateResultsFromMM(widthMM, aspect, rimIn);
      };

      const syncFromInches = (heightIn, widthIn, rimIn) => {
        const totalSidewallIn = (heightIn - rimIn) / 2;
        let widthMM = widthIn * 25.4;
        let aspect = ((totalSidewallIn * 25.4) / widthMM) * 100;

        widthMM = roundToStep(widthMM, parseFloat(widthMMField.step));
        aspect = roundToStep(aspect, parseFloat(aspectField.step));
        rimIn = roundToStep(rimIn, parseFloat(rimMMField.step));

        widthMMField.value = widthMM.toFixed(0);
        aspectField.value = aspect.toFixed(0);
        rimMMField.value = rimIn.toFixed(2);

        updateMetricCalc(false);
      };

      const updateInchCalc = (triggerSync = true) => {
        const heightIn = parseFloat(heightInField.value);
        const widthIn = parseFloat(widthInField.value);
        const rimIn = parseFloat(rimInField.value);

        if ([heightIn, widthIn, rimIn].some((value) => Number.isNaN(value))) {
          return;
        }

        if (triggerSync && !blockSync) {
          blockSync = true;
          syncFromInches(heightIn, widthIn, rimIn);
          blockSync = false;
        }
      };

      const updateMetricCalc = (triggerSync = true) => {
        const widthMM = parseFloat(widthMMField.value);
        const aspect = parseFloat(aspectField.value);
        const rimIn = parseFloat(rimMMField.value);

        if ([widthMM, aspect, rimIn].some((value) => Number.isNaN(value))) {
          return;
        }

        updateResultsFromMM(widthMM, aspect, rimIn);

        if (triggerSync && !blockSync) {
          blockSync = true;
          syncFromMetric(widthMM, aspect, rimIn);
          blockSync = false;
        }
      };

      const stepInput = (id, step) => {
        const input = document.getElementById(id);
        if (!input) return;

        const min = input.min ? parseFloat(input.min) : Number.NEGATIVE_INFINITY;
        const max = input.max ? parseFloat(input.max) : Number.POSITIVE_INFINITY;
        const current = parseFloat(input.value) || 0;
        const next = Math.min(max, Math.max(min, current + step));

        input.value = Number.isInteger(next) ? String(next) : next.toFixed(2).replace(/0+$/, "").replace(/\.$/, "");
        input.dispatchEvent(new Event("input", { bubbles: true }));
      };

      [heightInField, widthInField, rimInField].forEach((input) =>
        input.addEventListener("input", () => updateInchCalc())
      );

      [widthMMField, aspectField, rimMMField].forEach((input) =>
        input.addEventListener("input", () => updateMetricCalc())
      );

      document.querySelectorAll("[data-step-target]").forEach((button) => {
        button.addEventListener("click", () => {
          const { stepTarget, stepValue } = button.dataset;
          if (!stepTarget || !stepValue) return;
          stepInput(stepTarget, parseFloat(stepValue));
        });
      });

      updateInchCalc();
    };

    initTireCalculator();
    document.addEventListener("astro:page-load", initTireCalculator);
    document.addEventListener("astro:after-swap", initTireCalculator);
  </script>
</BaseLayout>
