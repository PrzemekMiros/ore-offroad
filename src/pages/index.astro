---
import BaseLayout from "../layouts/BaseLayout.astro";
import GridOne from "../components/home/gridOne.astro";
import GridTwo from "../components/home/GridTwo.astro";
import GridThree from "../components/home/GridThree.astro";
import GridFour from "../components/home/GridFour.astro";
import GridFive from "../components/home/GridFive.astro";
import GridSix from "../components/home/GridSix.astro";
import LoopText from "../components/home/LoopText.astro";
import BanerSix from "../components/home/BanerSix.astro";
import settings from "../content/ustawienia.json";
import siteLogoAsset from "../assets/images/global/logo.png";

const { site } = Astro;
const baseUrl = site ? site.toString().replace(/\/$/, "") : "";
const siteUrl = baseUrl ? `${baseUrl}/` : "/";
const siteLogo = site
  ? new URL(siteLogoAsset.src, site).toString()
  : siteLogoAsset.src;
const homeStructuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      url: siteUrl,
      name: settings.siteTitle,
      description: settings.metaDescription,
      publisher: {
        "@id": `${siteUrl}#organization`,
      },
      inLanguage: "pl-PL",
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}#organization`,
      url: siteUrl,
      name: settings.siteTitle,
      logo: {
        "@type": "ImageObject",
        url: siteLogo,
      },
    },
  ],
};
---

<BaseLayout
  title="Wszystko o offroadzie"
  description="Praktyczne porady i informacje o jeździe w terenie"
  showHero={false}
  structuredData={homeStructuredData}
>
  <GridOne />
  <GridTwo />
  <GridThree />
  <GridFour />
  <GridFive />
  <GridSix />


</BaseLayout>
