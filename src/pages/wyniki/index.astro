---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArchiveHero from "../../layouts/heroes/ArchiveHero.astro";

const items = (await getCollection("wyniki"))
  .map((entry) => ({ slug: entry.slug, ...entry.data }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout title="Wyniki rajdów terenowych" description="Archiwum wyników rajdów" showHero={false}>
  <ArchiveHero
    title="Archiwum wyników"
    lead="Wybierz rajd, aby zobaczyć pełne wyniki i klasy."
  />

  <section class="pb-14">
    {items.length ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((item) => (
          <a class="card" href={`/wyniki/${item.slug}`}>
            {item.thumbnail ? <img src={item.thumbnail} alt={item.title} loading="lazy" /> : null}
            <div class="card__body">
              <p class="card__eyebrow">{item.series ?? "Rajd"}</p>
              <h3 class="card__title">{item.title}</h3>
              <p class="card__meta">
                {item.date.toLocaleDateString("pl-PL", { day: "2-digit", month: "long", year: "numeric" })}
              </p>
              {item.location ? <p class="card__meta">{item.location}</p> : null}
              <span class="pill">Zobacz wyniki</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-muted">Brak opublikowanych wyników.</p>
    )}
  </section>
</BaseLayout>

<style>
  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
  }
  .card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }
  .card__body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .card__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 11px;
    color: #f97316;
    margin: 0;
  }
  .card__title {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
    color: #0f172a;
  }
  .card__meta {
    margin: 0;
    color: #6b7280;
    font-size: 14px;
  }
  .pill {
    align-self: flex-start;
    margin-top: 6px;
    padding: 8px 12px;
    border-radius: 999px;
    background: linear-gradient(135deg, #ff5a00, #ff8c62);
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.08em;
    font-size: 12px;
    border: 1px solid rgba(255, 90, 0, 0.4);
  }
  .text-muted {
    color: #6b7280;
    padding: 16px;
  }
</style>
