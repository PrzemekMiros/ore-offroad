---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArchiveHero from "../../layouts/heroes/ArchiveHero.astro";

const imageEntries = import.meta.glob("/src/content/imprezy/img/**/*", { eager: true });
const resolveEventImage = (file) => {
  if (!file) return null;
  let normalized = file;
  if (normalized.startsWith("/content/")) {
    normalized = `/src${normalized}`;
  }
  const entry = imageEntries[normalized];
  return entry?.default ?? null;
};

const currentYear = new Date().getFullYear();
const events = (await getCollection("imprezy"))
  .map((entry) => ({
    slug: entry.slug,
    ...entry.data,
  }))
  .filter((event) => event.dateStart.getFullYear() === currentYear)
  .sort((a, b) => a.dateStart.getTime() - b.dateStart.getTime());

const monthFormatter = new Intl.DateTimeFormat("pl-PL", { month: "long" });
const dayFormatter = new Intl.DateTimeFormat("pl-PL", { day: "2-digit", month: "short" });

const grouped = events.reduce((acc, event) => {
  const key = `${event.dateStart.getFullYear()}-${String(event.dateStart.getMonth() + 1).padStart(2, "0")}`;
  if (!acc[key]) acc[key] = [];
  acc[key].push(event);
  return acc;
}, {});

const monthSections = Object.entries(grouped)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([key, monthEvents]) => {
    const [year, month] = key.split("-");
    const monthName = monthFormatter.format(new Date(`${year}-${month}-01`));
    return { key, monthName, year, events: monthEvents };
  });

const statusClass = {
  "zapisy otwarte": "bg-emerald-50 text-emerald-700 border-emerald-300/60",
  "ostatnie miejsca": "bg-amber-50 text-amber-700 border-amber-300/60",
  potwierdzony: "bg-sky-50 text-sky-700 border-sky-300/60",
  "w przygotowaniu": "bg-neutral-100 text-neutral-700 border-neutral-300/70",
  wkrotce: "bg-orange-50 text-orange-700 border-orange-300/60",
};
---

<BaseLayout
  title="Kalendarz imprez offroadowych"
  description="Terminy wydarzen off-roadowych i motorsportowych."
  showHero={false}
>

  <ArchiveHero
    title="Kalendarz imprez offroadowych"
    lead="Terminy wydarzeń off-roadowych i motorsportowych."
    meta={events.length ? `${events.length} imprez` : "Brak imprez"}
  />

  <section class="py-12 md:pb-24">
    {!events.length ? (
      <div class="rounded-2xl border border-dashed border-[var(--accent)] bg-[var(--surface)] p-7 text-sm text-[var(--muted)]">
        Brak imprez.
      </div>
    ) : (
      <div class="grid gap-8 lg:grid-cols-[260px_minmax(0,1fr)]">
        <aside class="lg:sticky lg:top-38 lg:self-start">
          <div class="rounded-2xl border border-[var(--border)] bg-[var(--surface-muted)] px-5 py-9">
            <p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.2em] text-[var(--muted)]">Wybierz miesiąc</p>
            <ul class="space-y-2">
              {monthSections.map((section) => (
                <li>
                  <a
                    href={`#${section.key}`}
                    class="month-link group flex items-center justify-between rounded-xl border border-[var(--border)] bg-[var(--surface)] px-3 py-2 text-sm text-[var(--muted)] transition-colors hover:border-[var(--border)] hover:bg-[var(--surface-muted)] hover:text-[var(--accent)]"
                    data-month-link
                  >
                    <span class="capitalize">{section.monthName}</span>
                    <span class="month-count rounded-full bg-[var(--surface-muted)] px-2 py-0.5 text-[10px] text-[var(--muted)]">{section.events.length}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>

        <div class="space-y-8">
          {monthSections.map((section) => (
            <section id={section.key} class="scroll-mt-38 rounded-2xl border border-[var(--border)] bg-[var(--surface-muted)] px-5 md:p-7 md:pb-0">
              <div class="mb-6 flex items-center justify-between gap-4 border-b border-[var(--border)] pb-4">
                <h2 class="text-xl font-semibold capitalize text-[var(--text)]">{section.monthName}</h2>
                <p class="text-md uppercase font-semibold tracking-[0.05em] text-[var(--accent)]">{section.year}</p>
              </div>

              <div class="grid">
                {section.events.map((event) => {
                  const image = resolveEventImage(event.tileImage ?? event.thumbnail);
                  return (
                    <article class="group rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-4 transition-all hover:shadow-[0_10px_25px_rgba(15,23,42,0.05)] md:p-6 mb-8">
                      <div class="grid gap-4 md:grid-cols-2 md:items-start">

                        <div>
                          <div class="flex">
                            <div class="rounded-xl border border-[var(--border)] bg-[var(--surface)] px-3 pb-1 text-center">
                              <span class="mr-1 text-[10px] font-semibold leading-none text-[var(--text)]">
                                {event.dateStart.toLocaleDateString("pl-PL", { day: "2-digit" })}
                              </span>
                              <span class="text-[10px] uppercase tracking-[0.16em] leading-none text-[var(--muted)]">
                                {event.dateStart.toLocaleDateString("pl-PL", { month: "long" })}
                              </span>
                            </div>
                          </div>

                          <h3 class="mt-3 text-2xl font-semibold text-[var(--text)] leading-7 line-clamp-2">{event.title}</h3>
                          {event.description ? <p class="mt-2 text-sm text-[var(--muted)] line-clamp-2">{event.description}</p> : null}

                          <div class="mt-5 grid grid-cols-2 gap-2 text-xs">
                            <div class="rounded-lg border border-[var(--border)] bg-[var(--surface)] px-2.5 py-2 text-[var(--muted)]">
                              <p class="mb-2 text-[10px] uppercase tracking-[0.05em] text-[var(--accent)]">Lokalizacja</p>
                              <p class="font-medium text-[var(--text)]">{event.location}</p>
                            </div>
                            <div class="rounded-lg border border-[var(--border)] bg-[var(--surface)] px-2.5 py-2 text-[var(--muted)]">
                              <p class="mb-2 text-[10px] uppercase tracking-[0.05em] text-[var(--accent)]">Typ</p>
                              <p class="font-medium text-[var(--text)]">{event.type ?? "impreza"}</p>
                            </div>
                          </div>

                          <div class="mt-5">
                            <a
                              href={`/kalendarz-imprez/${event.slug}/`}
                              class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--accent)] transition-colors hover:text-[var(--text)]"
                            >
                              Szczegóły
                              <span class="text-[var(--accent)]" aria-hidden="true">+</span>
                            </a>
                          </div>
                        </div>

                        <div class="w-full max-w-[500px] overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--surface)] md:justify-self-end">
                          {image ? (
                            <Image
                              src={image}
                              alt={event.title}
                              class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105 md:h-68"
                              widths={[320, 500, 800]}
                              sizes="(max-width: 768px) 100vw, 500px"
                              loading="lazy"
                              placeholder="blur"
                            />
                          ) : (
                            <div class="grid h-44 w-full place-items-center text-[10px] uppercase tracking-[0.16em] text-[var(--muted)] md:h-full">
                              Brak zdjecia
                            </div>
                          )}
                        </div>

                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          ))}
        </div>
      </div>
    )}
  </section>
  <style>
    .month-link[data-active="true"] {
      border-color: var(--accent);
      background: var(--surface-muted);
      color: var(--text);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    .month-link[data-active="true"] .month-count {
      background: var(--accent);
      color: var(--surface);
    }
  </style>

  <script>
    const initSmoothAnchors = () => {
      if (window.__kalendarzSmoothScrollInit) return;
      window.__kalendarzSmoothScrollInit = true;

      document.addEventListener("click", (event) => {
        if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
          return;
        }
        if (!(event.target instanceof Element)) return;
        const link = event.target.closest('a[href^="#"]');
        if (!link) return;

        const targetId = link.getAttribute("href");
        if (!targetId || targetId === "#") return;
        const target = document.getElementById(targetId.slice(1));
        if (!target) return;

        event.preventDefault();
        const startY = window.pageYOffset || document.documentElement.scrollTop || 0;
        const scrollMarginTop = parseFloat(getComputedStyle(target).scrollMarginTop || "0") || 0;
        const targetY = Math.max(0, startY + target.getBoundingClientRect().top - scrollMarginTop);
        const distance = targetY - startY;

        if (Math.abs(distance) < 2) return;

        const duration = Math.min(900, Math.max(300, Math.abs(distance) * 0.6));
        const easeInOutCubic = (t) =>
          t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

        if (window.__kalendarzScrollRaf) {
          cancelAnimationFrame(window.__kalendarzScrollRaf);
        }

        const startTime = performance.now();
        const step = (now) => {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = easeInOutCubic(progress);
          window.scrollTo(0, startY + distance * eased);
          if (progress < 1) {
            window.__kalendarzScrollRaf = requestAnimationFrame(step);
          }
        };
        window.__kalendarzScrollRaf = requestAnimationFrame(step);
        history.replaceState(null, "", targetId);
      });
    };

    const initActiveMonthLinks = () => {
      const links = Array.from(document.querySelectorAll("[data-month-link]"));
      if (!links.length) return;

      const linkMap = new Map();
      links.forEach((link) => {
        const href = link.getAttribute("href");
        if (!href || href === "#") return;
        linkMap.set(href.slice(1), link);
      });

      const setActive = (hash) => {
        const id = hash?.startsWith("#") ? hash.slice(1) : hash;
        if (!id) return;
        links.forEach((link) => {
          link.dataset.active = "false";
        });
        const activeLink = linkMap.get(id);
        if (activeLink) activeLink.dataset.active = "true";
      };

      const sections = Array.from(linkMap.keys())
        .map((id) => document.getElementById(id))
        .filter(Boolean);

      const onHashChange = () => {
        if (location.hash) setActive(location.hash);
      };

      if (window.__kalendarzHashHandler) {
        window.removeEventListener("hashchange", window.__kalendarzHashHandler);
      }
      window.__kalendarzHashHandler = onHashChange;
      window.addEventListener("hashchange", onHashChange);

      if (window.__kalendarzActiveObserver) {
        window.__kalendarzActiveObserver.disconnect();
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries.filter((entry) => entry.isIntersecting);
          if (!visible.length) return;
          visible.sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          const best = visible[0].target;
          if (best?.id) setActive(best.id);
        },
        {
          rootMargin: "-30% 0px -60% 0px",
          threshold: [0, 0.2, 0.6, 1],
        }
      );

      sections.forEach((section) => observer.observe(section));
      window.__kalendarzActiveObserver = observer;

      if (location.hash) {
        setActive(location.hash);
      } else if (sections.length) {
        setActive(sections[0].id);
      }
    };

    initSmoothAnchors();
    initActiveMonthLinks();
    document.addEventListener("astro:page-load", initSmoothAnchors);
    document.addEventListener("astro:after-swap", initSmoothAnchors);
    document.addEventListener("astro:page-load", initActiveMonthLinks);
    document.addEventListener("astro:after-swap", initActiveMonthLinks);
  </script>
</BaseLayout>
