---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const imageEntries = import.meta.glob("/src/content/imprezy/img/**/*", { eager: true });
const resolveEventImage = (file) => {
  if (!file) return null;
  let normalized = file;
  if (normalized.startsWith("/content/")) {
    normalized = `/src${normalized}`;
  }
  const entry = imageEntries[normalized];
  return entry?.default ?? null;
};

const currentYear = new Date().getFullYear();
const events = (await getCollection("imprezy"))
  .map((entry) => ({
    slug: entry.slug,
    ...entry.data,
  }))
  .filter((event) => event.dateStart.getFullYear() === currentYear)
  .sort((a, b) => a.dateStart.getTime() - b.dateStart.getTime());

const monthFormatter = new Intl.DateTimeFormat("pl-PL", { month: "long" });
const dayFormatter = new Intl.DateTimeFormat("pl-PL", { day: "2-digit", month: "short" });

const grouped = events.reduce((acc, event) => {
  const key = `${event.dateStart.getFullYear()}-${String(event.dateStart.getMonth() + 1).padStart(2, "0")}`;
  if (!acc[key]) acc[key] = [];
  acc[key].push(event);
  return acc;
}, {});

const monthSections = Object.entries(grouped)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([key, monthEvents]) => {
    const [year, month] = key.split("-");
    const monthName = monthFormatter.format(new Date(`${year}-${month}-01`));
    return { key, monthName, year, events: monthEvents };
  });

const statusClass = {
  "zapisy otwarte": "bg-emerald-50 text-emerald-700 border-emerald-300/60",
  "ostatnie miejsca": "bg-amber-50 text-amber-700 border-amber-300/60",
  potwierdzony: "bg-sky-50 text-sky-700 border-sky-300/60",
  "w przygotowaniu": "bg-neutral-100 text-neutral-700 border-neutral-300/70",
  wkrotce: "bg-orange-50 text-orange-700 border-orange-300/60",
};
---

<BaseLayout
  title="Kalendarz imprez"
  description="Terminy wydarzen off-roadowych i motorsportowych."
  heroMeta={events.length ? `${events.length} imprez` : "Brak imprez"}
>

  <section class="py-12 md:pb-24">
    {!events.length ? (
      <div class="rounded-2xl border border-dashed border-[var(--border)] bg-[var(--surface)] p-7 text-sm text-[var(--muted)]">
        Brak imprez. Dodaj pierwszy wpis w `src/content/imprezy/`.
      </div>
    ) : (
      <div class="grid gap-8 lg:grid-cols-[260px_minmax(0,1fr)]">
        <aside class="lg:sticky lg:top-36 lg:self-start">
          <div class="rounded-2xl border border-[var(--border)] bg-[var(--surface-muted)] px-5 py-9">
            <p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.2em] text-[var(--muted)]">Wybierz miesiąc</p>
            <ul class="space-y-2">
              {monthSections.map((section) => (
                <li>
                  <a
                    href={`#${section.key}`}
                    class="group flex items-center justify-between rounded-xl border border-[var(--border)] px-3 py-2 text-sm text-[var(--muted)] bg-[var(--surface)] transition-colors hover:border-[var(--border)] hover:bg-[var(--surface-muted)] hover:text-[var(--text)]"
                  >
                    <span class="capitalize">{section.monthName}</span>
                    <span class="rounded-full bg-[var(--surface-muted)] px-2 py-0.5 text-[10px] text-[var(--muted)]">{section.events.length}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>

        <div class="space-y-8">
          {monthSections.map((section) => (
            <section id={section.key} class="scroll-mt-36 rounded-2xl border border-[var(--border)] bg-[var(--surface-muted)] px-5 md:p-7 md:pb-0">
              <div class="mb-6 flex items-center justify-between gap-4 border-b border-[var(--border)] pb-4">
                <h2 class="text-xl font-semibold capitalize text-[var(--text)]">{section.monthName}</h2>
                <p class="text-[11px] uppercase font-semibold tracking-[0.1em] text-[var(--muted)]">{section.year}</p>
              </div>

              <div class="grid">
                {section.events.map((event) => {
                  const image = resolveEventImage(event.tileImage ?? event.thumbnail);
                  return (
                    <article class="group rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-4 transition-all hover:shadow-[0_10px_25px_rgba(15,23,42,0.05)] md:p-6 mb-8">
                      <div class="grid gap-4 md:grid-cols-[minmax(450px,1fr)_minmax(0,1fr)] md:items-start">

                        <div>
                          <div class="flex">
                            <div class="rounded-xl border border-[var(--border)] bg-[var(--surface)] px-3 pb-1 text-center">
                              <span class="mr-1 text-[10px] font-semibold leading-none text-[var(--text)]">
                                {event.dateStart.toLocaleDateString("pl-PL", { day: "2-digit" })}
                              </span>
                              <span class="text-[10px] uppercase tracking-[0.16em] leading-none text-[var(--muted)]">
                                {event.dateStart.toLocaleDateString("pl-PL", { month: "short" })}
                              </span>
                            </div>
                          </div>

                          <h3 class="mt-3 text-2xl font-semibold leading-snug text-[var(--text)]">{event.title}</h3>
                          {event.description ? <p class="mt-2 text-sm text-[var(--muted)] line-clamp-2">{event.description}</p> : null}

                          <div class="mt-6 grid grid-cols-2 gap-2 text-xs">
                            <div class="rounded-lg border border-[var(--border)] bg-[var(--surface)] px-2.5 py-2 text-[var(--muted)]">
                              <p class="mb-2 text-[10px] uppercase tracking-[0.05em] text-[var(--accent)]">Lokalizacja</p>
                              <p class="font-medium text-[var(--text)]">{event.location}</p>
                            </div>
                            <div class="rounded-lg border border-[var(--border)] bg-[var(--surface)] px-2.5 py-2 text-[var(--muted)]">
                              <p class="mb-2 text-[10px] uppercase tracking-[0.05em] text-[var(--accent)]">Typ</p>
                              <p class="font-medium text-[var(--text)]">{event.type ?? "impreza"}</p>
                            </div>
                          </div>

                          <div class="mt-6 flex items-center justify-between gap-3">
                            <a
                              href={`/kalendarz-imprez/${event.slug}/`}
                              class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-[var(--accent)] transition-colors hover:text-[var(--text)]"
                            >
                              Szczegóły
                              <span class="text-[var(--accent)]" aria-hidden="true">+</span>
                            </a>
                            <p class="text-xs text-[var(--muted)]">
                              {dayFormatter.format(event.dateStart)}
                              {" - "}
                              {dayFormatter.format(event.dateEnd ?? event.dateStart)}
                            </p>
                          </div>
                        </div>

                        <div class="overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--surface)]">
                          {image ? (
                            <Image
                              src={image}
                              alt={event.title}
                              class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105 md:h-72"
                              widths={[450, 700, 960]}
                              sizes="(max-width: 900px) 100vw, 450px"
                              loading="lazy"
                            />
                          ) : (
                            <div class="grid h-44 w-full place-items-center text-[10px] uppercase tracking-[0.16em] text-[var(--muted)] md:h-full">
                              Brak zdjecia
                            </div>
                          )}
                        </div>

                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          ))}
        </div>
      </div>
    )}
  </section>
  <script>
    const initSmoothAnchors = () => {
      if (window.__kalendarzSmoothScrollInit) return;
      window.__kalendarzSmoothScrollInit = true;

      document.addEventListener("click", (event) => {
        const link = event.target.closest('a[href^="#"]');
        if (!link) return;

        const targetId = link.getAttribute("href");
        if (!targetId || targetId === "#") return;
        const target = document.querySelector(targetId);
        if (!target) return;

        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        event.preventDefault();
        target.scrollIntoView({ behavior: prefersReducedMotion ? "auto" : "smooth", block: "start" });
        history.replaceState(null, "", targetId);
      });
    };

    initSmoothAnchors();
    document.addEventListener("astro:page-load", initSmoothAnchors);
    document.addEventListener("astro:after-swap", initSmoothAnchors);
  </script>
</BaseLayout>
