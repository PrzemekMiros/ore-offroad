---
import { Image } from "astro:assets";
import baner from "../../assets/images/advertise/ad-ore.png";
---

<div class="relative hidden md:block">
  <div class="absolute inset-y-0 left-1/2 w-screen -translate-x-1/2 bg-gray-100 overflow-hidden -z-1">
</div>
  <div class="relative overflow-hidden rounded-md">
  <Image
    src={baner}
    alt="Baner strony"
    class="w-full h-auto"
    widths={[640, 960, 1280, 1600]}
    sizes="(max-width: 1280px) 100vw, 1280px"
    loading="lazy"
  />
  </div>
</div>
