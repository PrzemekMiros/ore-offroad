---
import { Image } from "astro:assets";
import baner from "../../assets/images/advertise/ad-jusn.png";
---

<div class="pb-20 pt-1">
  <a href="https://jusndesigneurope.com/" class="relative overflow-hidden rounded-md" target="_blank">
  <Image
    src={baner}
    alt="Baner strony"
    class="w-full h-auto aspect-[17/4] object-cover"
    widths={[640, 960, 1280, 1600]}
    sizes="(max-width: 1280px) 100vw, 1280px"
    loading="lazy"
  />
  </a>
</div>
