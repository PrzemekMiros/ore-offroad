      <div>
        <a href="/" class="text-xl font-semibold tracking-tighter text-black no-underline" aria-label="Logo">
          <img src={logo.src} class="w-24" width="294" height="190" alt="Logo Offroad" />
        </a>
      </div>
      <div class="hidden md:flex items-center">
        <div class="w-full max-w-[420px]">
          <Search
            id="site-search"
            className="pagefind-ui pagefind-ui--header"
            uiOptions={{ showImages: false, showDates: true, showCategories: true }}
          />
        </div>
      </div>
      <div class="flex justify-end items-center gap-2">
        <a
          href="/kalendarz-imprez/"
          class="flex h-9 px-3 items-center rounded-full border border-black/70 transition-colors hover:bg-black/5"
          aria-label="Przejdz do kalendarza imprez"
          title="Kalendarz imprez"
        >
        <span class="mt-0.5 uppercase text-[11px] tracking-[0.1em] leading-0 font-semibold">Kalendarz imprez</span>
          <svg class="h-4 w-4 ml-1 text-[var(--accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <rect x="3.5" y="5.5" width="17" height="15" rx="2"></rect>
            <path d="M7.5 3.5v4M16.5 3.5v4M3.5 9.5h17"></path>
          </svg>
        </a>
        <button
          type="button"
          class="hidden md:flex h-9 w-9 items-center justify-center rounded-full border border-black/70 text-[var(--accent)] transition-colors hover:bg-black/5"
          aria-label="Przełącz motyw"
          data-theme-toggle-btn
        >
          <span data-theme-icon-light aria-hidden="true">☀</span>
          <span data-theme-icon-dark aria-hidden="true" class="hidden">☾</span>
        </button>
      </div>

      <button
        class="w-22 border border-white/10 text-[10px] mr-0 ml-auto font-semibold uppercase tracking-[0.2em] text-black transition hover:bg-white/10 md:hidden"
        type="button"
        data-mobile-toggle
      >
        Menu
      </button>
    </div>

    <nav class="site-nav relative flex items-center justify-end md:justify-between gap-4 border-b border-black/20" data-site-nav>
      <div class="hidden items-center justify-center gap-5 md:flex">
        {
          navItemsWithLatest.map((item) => (
            <div class="mega-item" data-mega-item>
              <a
                class={`${linkClass(item.href)} mega-link text-[11px] uppercase font-semibold tracking-[1px] transition-colors hover:text-black`}
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                data-mega-trigger
              >
                <span>{item.label}</span>
                <span class="mega-arrow" aria-hidden="true">+</span>
              </a>

              <div class="mega-panel" data-mega-panel>
                <div class="mega-panel-inner">
                  <div class="mega-topline">
                    <p>{item.description}</p>
                  </div>
                  <div class="mega-grid">
                    {
                      item.columns.map((column) => (
                        <section>
                          <ul>
                            {
                              column.links.map((link) => (
                                <li>
                                  <a href={link.href}>
                                    <span class="mega-link-label">{link.label}</span>
                                  </a>
                                </li>
                              ))
                            }
                          </ul>
                        </section>
                      ))
                    }
                    <aside
                      class="mega-featured"
                    >
                      {item.featured?.image ? (
                        <Image
                          src={item.featured.image}
                          alt={item.featured.title}
                          class="mega-featured-image"
                          widths={[320, 480, 640, 960]}
                          sizes="(max-width: 1024px) 100vw, 420px"
                          loading="lazy"
                        />
                      ) : null}
                      <div class="mega-featured-content">
                        <p class="mega-featured-eyebrow">{item.featured.eyebrow}</p>
                        <a href={item.featured.href} class="mega-featured-title">
                          {item.featured.title}
                        </a>
                      </div>
                    </aside>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </nav>

    <div
      class="fixed inset-x-0 top-0 z-[60] h-screen flex flex-col gap-6 overflow-hidden bg-[#0a0a0a] p-8 text-white transition-all duration-300 pointer-events-none opacity-0 md:hidden"
      id="mobile-menu"
      data-mobile-menu
    >
      <div class="flex items-center justify-between">
        <span class="text-xs font-semibold uppercase tracking-widest text-gray-500">Nawigacja</span>
        <button
          class="text-[10px] font-semibold uppercase tracking-widest text-orange-500"
          type="button"
          data-mobile-close
        >
          Zamknij
        </button>
      </div>

      <div class="flex flex-col gap-6 pt-12">
        {
          navItemsWithLatest.map((item) => (
            <div class="flex flex-col gap-3">
              <a class="text-md font-semibold text-white no-underline" href={item.href} data-mobile-link>
                {item.label}
              </a>
              <div class="mt-3 border border-b border-white/10"></div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const setupHeaderScroll = () => {
    const nav = document.querySelector("[data-site-nav]");
    if (!nav || nav.dataset.scrollReady === "true") return;
    nav.dataset.scrollReady = "true";

    let lastY = window.scrollY;
    let ticking = false;
    const offset = 80;
    const minDelta = 12;

    const update = () => {
      const currentY = window.scrollY;
      const delta = currentY - lastY;
      const mobileMenu = document.querySelector("[data-mobile-menu]");
      const isMenuOpen = mobileMenu?.classList.contains("is-open");

      if (isMenuOpen || currentY <= offset) {
        nav.classList.remove("is-hidden");
      } else if (delta > minDelta) {
        nav.classList.add("is-hidden");
      } else if (delta < -minDelta) {
        nav.classList.remove("is-hidden");
      }

      lastY = currentY;
      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    update();
  };

  const syncThemeToggleState = () => {
    const html = document.documentElement;
    const isDark = html.dataset.theme === "dark";
    document.querySelectorAll("[data-theme-icon-light]").forEach((el) => {
      el.classList.toggle("hidden", isDark);
    });
    document.querySelectorAll("[data-theme-icon-dark]").forEach((el) => {
      el.classList.toggle("hidden", !isDark);
    });
  };

  const setupThemeToggle = () => {
    const btn = document.querySelector("[data-theme-toggle-btn]");
    if (!btn || btn.dataset.ready === "true") return;
    btn.dataset.ready = "true";
    btn.addEventListener("click", () => {
      const api = window.astroThemeToggle;
      if (!api || typeof api.getTheme !== "function" || typeof api.setTheme !== "function") return;
      const current = api.getTheme();
      api.setTheme(current === "dark" ? "light" : "dark");
      syncThemeToggleState();
    });
    syncThemeToggleState();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupThemeToggle, { once: true });
    document.addEventListener("DOMContentLoaded", setupHeaderScroll, { once: true });
  } else {
    setupThemeToggle();
    setupHeaderScroll();
  }
  document.addEventListener("astro:page-load", setupThemeToggle);
  document.addEventListener("astro:page-load", setupHeaderScroll);
</script>

<style>
