  .mega-link-label {
    display: block;
    color: #0f172a;
    font-size: 0.83rem;
    font-weight: 700;
    line-height: 1.3;
  }


  .mega-featured {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    padding: 0.9rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background-color: #0b0b0b;
    color: #fff;
    min-height: 220px;
    display: flex;
    flex-direction: column;
  }

  .mega-featured::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 35%, rgba(0, 0, 0, 0.78) 100%);
    z-index: 1;
  }

  .mega-featured-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .mega-featured-content {
    position: relative;
    z-index: 2;
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .mega-featured-eyebrow {
    margin: 0;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 800;
  }

  .mega-featured-title {
    margin: 0;
    display: block;
    font-size: 1.2rem;
    line-height: 1;
    font-family: "Gilroy", "Zalando Sans SemiExpanded", "Segoe UI", sans-serif;
    letter-spacing: 0.03em;
    text-decoration: none;
    color: inherit;
  }

  html[data-theme="dark"] .mega-link {
    color: #e5e7eb !important;
  }

  html[data-theme="dark"] .mega-link:hover,
  html[data-theme="dark"] .mega-link:focus-visible {
    color: #ffffff !important;
  }

  html[data-theme="dark"] .mega-panel-inner {
    border-color: rgba(148, 163, 184, 0.24);
    background:
      radial-gradient(circle at 10% 0%, rgba(249, 115, 22, 0.32), transparent 42%),
      radial-gradient(circle at 92% 100%, rgba(0, 0, 0, 0.5), transparent 55%),
      #0b0b0b;
  }

  html[data-theme="dark"] .mega-topline {
    border-bottom-color: rgba(148, 163, 184, 0.24);
  }

  html[data-theme="dark"] .mega-topline p {
    color: rgba(226, 232, 240, 0.78);
  }

  html[data-theme="dark"] .mega-grid section {
    background: rgba(15, 23, 42, 0.72);
    border-color: rgba(148, 163, 184, 0.22);
  }

  html[data-theme="dark"] .mega-grid li a:hover,
  html[data-theme="dark"] .mega-grid li a:focus-visible {
    border-color: rgba(56, 189, 248, 0.42);
    background: rgba(56, 189, 248, 0.12);
  }

  html[data-theme="dark"] .mega-link-label {
    color: #f3f4f6;
  }


  html[data-theme="dark"] .mega-featured {
    border-color: rgba(148, 163, 184, 0.22);
  }

  .mega-item:hover .mega-panel,
  .mega-item:focus-within .mega-panel,
  .mega-item.is-open .mega-panel {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mega-item:hover .mega-arrow,
  .mega-item:focus-within .mega-arrow,
  .mega-item.is-open .mega-arrow {
    transform: rotate(45deg);
  }

  @media (max-width: 767px) {
    .mega-panel {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const toggle = document.querySelector("[data-mobile-toggle]");
    const menu = document.querySelector("[data-mobile-menu]");
    const closeBtn = document.querySelector("[data-mobile-close]");
    const links = document.querySelectorAll("[data-mobile-link]");
    const megaItems = Array.from(document.querySelectorAll("[data-mega-item]"));
    const megaTriggers = Array.from(document.querySelectorAll("[data-mega-trigger]"));

    if (toggle && menu) {
      const setOpen = (isOpen) => {
        menu.classList.toggle("is-open", isOpen);
        document.body.style.overflow = isOpen ? "hidden" : "";
      };

      toggle.addEventListener("click", () => setOpen(true));
      closeBtn?.addEventListener("click", () => setOpen(false));
      links.forEach((link) => {
        link.addEventListener("click", () => setOpen(false));
      });
    }

    if (megaItems.length && megaTriggers.length) {
      const closeAllMega = () => megaItems.forEach((item) => item.classList.remove("is-open"));

      megaTriggers.forEach((trigger) => {
        trigger.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            closeAllMega();
            trigger.blur();
          }
        });
      });

      document.addEventListener("click", (event) => {
        if (!event.target.closest("[data-mega-item]")) {
          closeAllMega();
        }
      });
    }
  });
</script>
