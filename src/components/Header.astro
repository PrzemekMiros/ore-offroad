const linkClass = (href) =>
  isActive(href)
    ? "px-1 py-2.5 text-black no-underline transition"
    : "px-1 py-2.5 text-black/70 no-underline transition hover:text-black";

const navItemsWithLatest = navItems.map((item) => {
  const categorySlug = slugifyTitle(item.label);
  const latest = latestByCategory.get(categorySlug);
  const posts = postsByCategory.get(categorySlug) ?? [];
  const totalSlots = item.columns.reduce(
    (sum, column) => sum + (column.links?.length ?? 0),
    0
  );
  const maxPosts = totalSlots || 6;
  const sliced = posts.slice(0, maxPosts);
  let offset = 0;

  const columns =
    posts.length === 0
      ? item.columns
      : item.columns.map((column) => {
          const fallbackLinks = column.links ?? [];
          const count = fallbackLinks.length || 3;
          const postsForColumn = sliced.slice(offset, offset + count);
          offset += count;
          const links = postsForColumn.map((post) => ({
            href: getPostUrl(post),
            label: post.title ?? post.slug,
            meta: toMeta(post),
          }));
          if (links.length < count && fallbackLinks.length) {
            links.push(...fallbackLinks.slice(links.length));
          }
          return { ...column, links };
        });

  if (!latest) return { ...item, columns };

  const title = latest.title ?? latest.slug;
  const image = resolveArticleImage(latest.tileImage ?? latest.thumbnail);
  const href = getPostUrl(latest);

  return {
    ...item,
    columns,
    featured: {
      eyebrow: "Najnowszy wpis",
      title,
      href,
      cta: "Czytaj wpis",
      image,
    },
  };
});
---

<header class="fixed left-0 right-0 top-0 z-500 bg-white" data-site-header>
