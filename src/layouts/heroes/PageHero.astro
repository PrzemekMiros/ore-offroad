---
const { title, lead, meta } = Astro.props;
const { site, url } = Astro;
// import { Image } from "astro:assets";
// import BanerPage from "../../components/home/BanerPage.astro";
const baseUrl = site ? site.toString().replace(/\/$/, "") : "";
const homeUrl = baseUrl ? `${baseUrl}/` : "/";
const currentUrl = baseUrl ? new URL(url.pathname, baseUrl).toString() : url.pathname;
---

<!-- 
<BanerPage />
-->

<section class="relative">
  <div class="grid grid-cols-1 relative">
    <div class="relative flex flex-col justify-center pb-4 pt-40 z-10">
      <nav
        class="text-[8px] md:text-[10px] uppercase tracking-[0.1em] text-gray-600 mb-3 md:mb-4 font-semibold"
        aria-label="Breadcrumb"
        itemscope
        itemtype="https://schema.org/BreadcrumbList"
      >
        <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href={homeUrl} itemprop="item" class="hover:text-white">
            <span itemprop="name">Główna</span>
          </a>
          <meta itemprop="position" content="1" />
        </span>
        <span class="text-[var(--accent2)]"> > </span>
        <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <meta itemprop="item" content={currentUrl} />
          <span itemprop="name">
            {title}
          </span>
          <meta itemprop="position" content="2" />
        </span>
      </nav>
      <h1 class="text-3xl text-black sm:text-3xl md:text-4xl lg:text-5xl font-semibold leading-[1.1] tracking-tight max-w-3xl">
        {title}
      </h1>
    </div>
  </div>
</section>

  <section class="relative py-5 border-b border-gray-200">
    {meta ? (
      <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[var(--accent)]">{meta}</p>
    ) : null}

  </section>

