---
import { Image } from "astro:assets";
import heroImage from "../../assets/images/sections/hero-page.png";
const { title, lead, meta } = Astro.props;
const { site, url } = Astro;
const baseUrl = site ? site.toString().replace(/\/$/, "") : "";
const homeUrl = baseUrl ? `${baseUrl}/` : "/";
const currentUrl = baseUrl ? new URL(url.pathname, baseUrl).toString() : url.pathname;
---

<section class="relative">
  <div class="grid grid-cols-1 relative">
    <div class="relative flex flex-col justify-center pb-4 pt-40 z-10">
      <nav
        class="text-[8px] md:text-[10px] uppercase tracking-[0.1em] text-gray-600 mb-3 md:mb-4 font-semibold"
        aria-label="Breadcrumb"
        itemscope
        itemtype="https://schema.org/BreadcrumbList"
      >
        <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href={homeUrl} itemprop="item" class="hover:text-white">
            <span itemprop="name">Główna</span>
          </a>
          <meta itemprop="position" content="1" />
        </span>
        <span class="text-[var(--accent)]"> > </span>
        <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <meta itemprop="item" content={currentUrl} />
          <span itemprop="name">
            {title}
          </span>
          <meta itemprop="position" content="2" />
        </span>
      </nav>
      <h1 class="text-3xl text-black sm:text-3xl md:text-4xl lg:text-5xl font-semibold leading-[1.1] tracking-tight max-w-5xl">
        {title}
      </h1>
    </div>
  </div>
</section>

  <section class="relative py-5 border-b border-gray-200">
    {meta ? (
      <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[var(--accent)]">{meta}</p>
    ) : (
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 md:mb-0">
        <span class="text-[10px] mt-1 md:mt-0 text-gray-400 uppercase font-semibold tracking-tighter">Średnia opinia w </span>
        
        <div class="flex items-center gap-3">
          <span class="text-xl font-black text-[#002B49] tracking-tighter">Google</span>
          <div class="flex items-center gap-1">
            <div class="flex text-orange-400 text-xs">★★★★★</div>
            <span class="text-gray-900 font-semibold text-xs ml-1">5.0</span>
          </div>
        </div>

        <span class="text-[11px] text-gray-500 font-medium hidden sm:block">
      
        </span>
      </div>
    )}

  </section>

